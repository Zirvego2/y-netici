# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # --- Read-only file system hatası çözümü ---
      # Xcode'un kök dizine (/) yazmaya çalışmasını engelleyip proje içine yönlendiriyoruz
      config.build_settings['SYMROOT'] = '${SRCROOT}/../build/ios'
      config.build_settings['OBJROOT'] = '${SRCROOT}/../build/ios'
      
      # Diğer standart ayarlar
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'NO'
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'

      # --- -G bayrağı temizleme (Flags üzerinden) ---
      %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS OTHER_SWIFT_FLAGS OTHER_LDFLAGS].each do |flag_key|
        flags = config.build_settings[flag_key]
        if flags.is_a?(Array)
          config.build_settings[flag_key] = flags.reject { |f| f.to_s.strip =~ /^-G/ }
        elsif flags.is_a?(String)
          config.build_settings[flag_key] = flags.split.reject { |f| f =~ /^-G/ }.join(' ')
        end
      end
    end
  end

  # --- xcconfig dosyalarını fiziksel olarak tarayıp -G bayrağını silme ---
  xcconfig_globs = [
    "Pods/Target Support Files/**/*.xcconfig",
    "Flutter/*.xcconfig"
  ]

  xcconfig_globs.each do |glob|
    Dir.glob(glob).each do |path|
      begin
        contents = File.read(path)
        # Regex ile -G ve yanındaki tüm karakterleri (ör: -G1) kaldırır
        updated = contents.gsub(/\s+-G\S*/, "")
        if updated != contents
          File.write(path, updated)
        end
      rescue => e
        Pod::UI.warn("Could not patch xcconfig #{path}: #{e}")
      end
    end
  end
end
