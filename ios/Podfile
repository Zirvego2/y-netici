# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'NO'
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'

      %w[
        OTHER_CFLAGS
        OTHER_CPLUSPLUSFLAGS
        OTHER_SWIFT_FLAGS
        OTHER_LDFLAGS
      ].each do |flag_key|
        flags = config.build_settings[flag_key]

        if flags.is_a?(Array)
          config.build_settings[flag_key] = flags.reject do |flag|
            token = flag.to_s.strip
            token == '-G' || token.start_with?('-G')
          end
        elsif flags.is_a?(String)
          cleaned = flags
            .split(/\s+/)
            .reject { |token| token == '-G' || token.start_with?('-G') }
            .join(' ')
            .strip
          config.build_settings[flag_key] = cleaned
        end
      end
    end
  end

  # Some pods (notably BoringSSL-GRPC / gRPC-Core) can inject compiler flags via *.xcconfig files.
  # Pod build_settings changes above won't remove tokens defined in those xcconfig files.
  # This makes the build deterministic in CI by stripping any `-G` / `-G*` tokens from xcconfig files.
  xcconfig_globs = [
    "Pods/Target Support Files/BoringSSL-GRPC/**/*.xcconfig",
    "Pods/Target Support Files/gRPC-Core/**/*.xcconfig",
    "Pods/Target Support Files/GoogleDataTransport/**/*.xcconfig",
    "Pods/Target Support Files/FirebaseMessaging/**/*.xcconfig",
  ]

  xcconfig_globs.each do |glob|
    Dir.glob(glob).each do |path|
      begin
        contents = File.read(path)
        # Token-based removal: remove -G and -G* occurrences in flag lines without breaking other flags.
        updated = contents.lines.map do |line|
          if line =~ /OTHER_(CFLAGS|CPLUSPLUSFLAGS|LDFLAGS|SWIFT_FLAGS)\s*=/
            tokens = line.split(/\s+/)
            tokens.reject! { |t| t == '-G' || t.start_with?('-G') }
            tokens.join(' ')
          else
            line
          end
        end.join
        if updated != contents
          File.write(path, updated)
        end
      rescue => e
        Pod::UI.warn("Could not patch xcconfig #{path}: #{e}")
      end
    end
  end
end
